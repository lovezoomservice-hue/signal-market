{
  "version": 2,
  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node" },
    { "src": "founder_dashboard/ui/*.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/founder(/.*)?", "dest": "/founder_dashboard/ui$1" },
    { "src": "/founder/api/(.*)", "dest": "/founder_dashboard/api/$1" }
  ]
}
