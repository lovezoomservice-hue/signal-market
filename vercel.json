{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/auth/(register|login|me|keys)",
      "dest": "/api/auth/index.js"
    },
    {
      "src": "/api/auth",
      "dest": "/api/auth/index.js"
    },
    {
      "src": "/api/billing/(usage|checkout|webhook)",
      "dest": "/api/billing.js"
    },
    {
      "src": "/api/billing",
      "dest": "/api/billing.js"
    },
    {
      "src": "/api/topics/(.+)/stage",
      "dest": "/api/topics/index.js?id=$1&action=stage"
    },
    {
      "src": "/api/topics/(.+)",
      "dest": "/api/topics/index.js?id=$1"
    },
    {
      "src": "/api/events/(.+)",
      "dest": "/api/events/index.js?id=$1"
    },
    {
      "src": "/api/watchlist/triggers",
      "dest": "/api/watchlist.js"
    },
    {
      "src": "/api/signals/(.+)/evidence",
      "dest": "/api/signals.js?id=$1&action=evidence"
    },
    {
      "src": "/api/signals/(.+)/lifecycle",
      "dest": "/api/signals.js?id=$1&action=lifecycle"
    },
    {
      "src": "/api/signals/(.+)",
      "dest": "/api/signals.js?id=$1"
    },
    {
      "src": "/api/candidates/(.+)/promote",
      "dest": "/api/candidates.js?id=$1&action=promote"
    },
    {
      "src": "/api/candidates/(.+)/reject",
      "dest": "/api/candidates.js?id=$1&action=reject"
    },
    {
      "src": "/api/candidates/(.+)",
      "dest": "/api/candidates.js?id=$1"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1.js"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}